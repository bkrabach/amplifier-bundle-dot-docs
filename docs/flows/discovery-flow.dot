// Discovery Flow — The Big Boss Recipe
// Reads your profile, figures out what changed, then sends work to helpers.
// Think of it like a school principal assigning homework to different classes.

digraph discovery_flow {
    // --- Graph settings ---
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Discovery Flow — The Big Boss\nReads your profile, checks what changed, sends work to helper recipes"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"

    // --- Node defaults ---
    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    // === START / END ===
    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="All Done!", shape=oval, fillcolor="#e0e0e0"]

    // =====================================================================
    // STAGE 1: Setup — "What repos do we have and what changed?"
    // =====================================================================
    subgraph cluster_setup {
        label="Stage 1: Setup\n\"What repos do we have?\""
        style="filled,rounded"
        fillcolor="#f9f9f9"
        color="#999999"

        read_profile    [label="Read Profile", shape=box, fillcolor="#bbdefb"
                         tooltip="Read the YAML file that lists all your repos"]
        determine_tiers [label="Check Changes", shape=box, fillcolor="#bbdefb"
                         tooltip="Look at git history to see what changed since last time"]
        display_plan    [label="Show the Plan", shape=box, fillcolor="#bbdefb"
                         tooltip="Print a table showing which repos need work"]
    }

    // =====================================================================
    // STAGE 2: Investigation — "Go study each repo"
    // =====================================================================
    subgraph cluster_investigation {
        label="Stage 2: Investigation\n\"Go study each repo\""
        style="filled,rounded"
        fillcolor="#f9f9f9"
        color="#999999"

        log_intent   [label="Log What To Do", shape=box, fillcolor="#bbdefb"
                      tooltip="For each repo, write down what kind of work it needs"]
        filter_tiers [label="Sort Into Groups", shape=box, fillcolor="#bbdefb"
                      tooltip="Split repos into groups: full scan, partial scan, patch, skip"]
        prescan      [label="Quick Look\n(prescan)", shape=box, fillcolor="#e0e0e0"
                      tooltip="Run the prescan sub-recipe to pick topics for each repo"
                      style="filled,rounded,dashed"]
        investigate  [label="Deep Dive\n(investigate)", shape=box, fillcolor="#e0e0e0"
                      tooltip="Run the investigate sub-recipe with 3 agent teams per topic"
                      style="filled,rounded,dashed"]
    }

    // --- Approval Gate ---
    approval [label="Human Approves?", shape=diamond, fillcolor="#ffe0b2"
              tooltip="A human reviews the plan and results before continuing"]

    // =====================================================================
    // STAGE 3: Synthesis — "Turn research into polished diagrams"
    // =====================================================================
    subgraph cluster_synthesis {
        label="Stage 3: Synthesis\n\"Make the final diagrams\""
        style="filled,rounded"
        fillcolor="#f9f9f9"
        color="#999999"

        run_synthesis [label="Build Diagrams\n(synthesis)", shape=box, fillcolor="#e0e0e0"
                       tooltip="Run the synthesis sub-recipe to create polished DOT files"
                       style="filled,rounded,dashed"]
        content_hash  [label="Check Duplicates", shape=box, fillcolor="#bbdefb"
                       tooltip="See if the new diagram is different from the old one"]
        tier3_check   [label="Patch Quality\nCheck", shape=box, fillcolor="#c8e6c9"
                       tooltip="For small-change repos, run orphan/cycle/diff checks"]
        write_meta    [label="Save Records", shape=box, fillcolor="#bbdefb"
                       tooltip="Write last-run.json and manifest.json for each repo"]
        summary       [label="Print Summary", shape=box, fillcolor="#bbdefb"
                       tooltip="Show how many repos were processed, skipped, or errored"]
        reconcile     [label="Find Orphans", shape=box, fillcolor="#bbdefb"
                       tooltip="Check if any old repo folders no longer match the profile"]
    }

    // === TIER DECISION ===
    tier_decision [label="What tier?", shape=diamond, fillcolor="#fff9c4"
                   tooltip="Tier -1/0=Skip, 1=Full, 2=Wave, 3=Patch"]

    // === EDGES ===
    start -> read_profile

    // Stage 1 flow
    read_profile -> determine_tiers
    determine_tiers -> display_plan

    // Stage 1 → Tier decision
    display_plan -> tier_decision

    // Tier routing
    tier_decision -> log_intent    [label="Tier 1, 2, or 3\n(needs work)"]
    tier_decision -> done          [label="All repos\nskipped", style=dashed, color="#999999"]

    // Stage 2 flow
    log_intent -> filter_tiers
    filter_tiers -> prescan        [label="Tier 1 & 2 repos"]
    prescan -> investigate         [label="Topics chosen"]
    filter_tiers -> investigate    [label="Tier 3 repos\n(skip prescan)", style=dashed]
    investigate -> approval

    // Approval gate
    approval -> run_synthesis      [label="Approved", color="#4caf50"]
    approval -> done               [label="Denied", style=dashed, color="#f44336"]

    // Stage 3 flow
    run_synthesis -> content_hash
    content_hash -> tier3_check    [label="Tier 3 repos"]
    content_hash -> write_meta     [label="Tier 1 & 2"]
    tier3_check -> write_meta
    write_meta -> summary
    summary -> reconcile
    reconcile -> done

    // =====================================================================
    // LEGEND
    // =====================================================================
    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10

        node [shape=box, fontsize=9, width=1.6]

        leg_bash   [label="Script Step", fillcolor="#bbdefb"]
        leg_agent  [label="AI Agent Step", fillcolor="#c8e6c9"]
        leg_sub    [label="Sub-Recipe Call", fillcolor="#e0e0e0", style="filled,rounded,dashed"]
        leg_gate   [label="Approval Gate", shape=diamond, fillcolor="#ffe0b2"]
        leg_start  [label="Start / End", shape=oval, fillcolor="#e0e0e0"]

        leg_bash -> leg_agent -> leg_sub -> leg_gate -> leg_start [style=invis]
    }
}
