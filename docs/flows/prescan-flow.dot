// Prescan Flow — The Quick Look
// Gathers basic info about a repo, then an AI picks the best topics to study.
// Like flipping through a book's table of contents before reading it.

digraph prescan_flow {
    // --- Graph settings ---
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Prescan Flow — The Quick Look\nGathers basic repo info, then an AI picks the best topics to study"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.7
    ranksep=0.8
    bgcolor="white"

    // --- Node defaults ---
    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    // === START / END ===
    start [label="Start\n(repo path)", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done!\nTopics Chosen", shape=oval, fillcolor="#e0e0e0"]

    // =====================================================================
    // STEP 1: Gather Metadata — "Look at the outside of the box"
    // =====================================================================
    subgraph cluster_gather {
        label="Step 1: Gather Info\n\"Look at the outside of the box\""
        style="filled,rounded"
        fillcolor="#f5f9ff"
        color="#999999"

        gather [label="Gather Metadata", shape=box, fillcolor="#bbdefb"
                tooltip="A script collects basic facts about the repo"]

        // What it collects
        subgraph cluster_collected {
            label="What it collects"
            style="filled,rounded"
            fillcolor="white"
            color="#cccccc"
            fontsize=9

            node [shape=note, fillcolor="white", fontsize=9]

            top_level   [label="Top-level files\n& folders"]
            readme      [label="README excerpt\n(first 2000 chars)"]
            languages   [label="Languages used\n(.py, .js, etc.)"]
            manifests   [label="Build files\n(package.json, etc.)"]
        }

        gather -> top_level  [arrowhead=none, style=dotted]
        gather -> readme     [arrowhead=none, style=dotted]
        gather -> languages  [arrowhead=none, style=dotted]
        gather -> manifests  [arrowhead=none, style=dotted]
    }

    // =====================================================================
    // STEP 2: Select Topics — "The AI picks what to study"
    // =====================================================================
    subgraph cluster_select {
        label="Step 2: Pick Topics\n\"The AI decides what's worth studying\""
        style="filled,rounded"
        fillcolor="#f0f7f0"
        color="#999999"

        select [label="AI Picks Topics", shape=box, fillcolor="#c8e6c9"
                tooltip="An AI agent reads the metadata and picks 1-6 topics"]

        // What it considers
        subgraph cluster_considers {
            label="What the AI thinks about"
            style="filled,rounded"
            fillcolor="white"
            color="#cccccc"
            fontsize=9

            node [shape=box, fillcolor="#f5f5f5", fontsize=9, style="filled,rounded"]

            q_arch  [label="How is the code\norganized?"]
            q_flow  [label="How does data\nmove around?"]
            q_state [label="How is state\nmanaged?"]
        }

        select -> q_arch  [arrowhead=none, style=dotted]
        select -> q_flow  [arrowhead=none, style=dotted]
        select -> q_state [arrowhead=none, style=dotted]
    }

    // =====================================================================
    // OUTPUT — The chosen topics
    // =====================================================================
    subgraph cluster_output {
        label="Output"
        style="filled,rounded"
        fillcolor="#f9f9f9"
        color="#999999"

        topic_list [label="Topic List\n(JSON array)", shape=cylinder, fillcolor="#e1bee7"
                    tooltip="Each topic has a name, slug, and rationale"]

        // Example topics
        example [label="Example topics:\n- Module Architecture\n- Request Pipeline\n- Plugin System", shape=note
                 fillcolor="white", fontsize=9]

        topic_list -> example [arrowhead=none, style=dotted]
    }

    // === EDGES ===
    start -> gather
    gather -> select    [label="Metadata\npassed along"]
    select -> topic_list [label="1-6 topics\nchosen"]
    topic_list -> done

    // =====================================================================
    // LEGEND
    // =====================================================================
    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10

        node [shape=box, fontsize=9, width=1.6]

        leg_bash   [label="Script Step", fillcolor="#bbdefb"]
        leg_agent  [label="AI Agent Step", fillcolor="#c8e6c9"]
        leg_file   [label="Output File", shape=note, fillcolor="white"]
        leg_data   [label="Data Store", shape=cylinder, fillcolor="#e1bee7"]
        leg_start  [label="Start / End", shape=oval, fillcolor="#e0e0e0"]

        leg_bash -> leg_agent -> leg_file -> leg_data -> leg_start [style=invis]
    }
}
