// This recipe investigates a single code repository by sending AI agents to study each key topic from three angles — tracing code, observing patterns, and mapping connections.
digraph dotfiles_investigate {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Repo Deep Dive\nInvestigates a single repository from multiple angles to understand how it works"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="341cdf07729a0f84eda362c6524a5115616254713d0c4482e27165f2e181954e"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done!", shape=oval, fillcolor="#e0e0e0"]

    step_prepare_workspace [label="Set Up Folders\n\"Get organized\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="mkdir -p '{{investigation_dir}}/wave-1' mkdir -p '{{investigation_dir}}/foreman-notes' echo 'Workspa"]
    step_select_topics [label="Scan & Pick Topics\n\"What should we study?\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:explorer"]
    step_build_topic_paths [label="Organize Topic List\n\"Sort out the details\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="# Write topics to temp file first to avoid string delimiter issues # when {{topics}} contains quotes"]
    step_wave1_code_tracers [label="Trace Each Topic's Code\n\"How does it work?\"\n(for each topic)", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="parallax-discovery:code-tracer"]
    cond_step_wave1_behavior_observers [label="Full study?", shape=diamond, fillcolor="#fff9c4"]
    step_wave1_behavior_observers [label="Study Real Patterns\n\"What actually happens?\"\n(for each topic)", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="parallax-discovery:behavior-observer"]
    cond_step_wave1_integration_mappers [label="Full study?", shape=diamond, fillcolor="#fff9c4"]
    step_wave1_integration_mappers [label="Map Connections\n\"Where do parts meet?\"\n(for each topic)", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="parallax-discovery:integration-mapper"]
    step_lead_investigator [label="Review All Findings\n\"What did we learn?\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="parallax-discovery:lead-investigator"]
    step_build_manifest [label="Package the Results\n\"Wrap it all up\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="# Write template variables to temp files to avoid string delimiter issues cat > /tmp/dotfiles_manife"]

    start -> step_prepare_workspace
    step_prepare_workspace -> step_select_topics
    step_select_topics -> step_build_topic_paths
    step_build_topic_paths -> step_wave1_code_tracers
    step_wave1_code_tracers -> cond_step_wave1_behavior_observers
    cond_step_wave1_behavior_observers -> step_wave1_behavior_observers [label="tier != '3'"]
    step_wave1_code_tracers -> cond_step_wave1_integration_mappers
    cond_step_wave1_integration_mappers -> step_wave1_integration_mappers [label="tier != '3'"]
    step_wave1_code_tracers -> step_lead_investigator
    step_lead_investigator -> step_build_manifest
    cond_step_wave1_behavior_observers -> step_lead_investigator [label="skip", style=dashed]
    cond_step_wave1_integration_mappers -> step_lead_investigator [label="skip", style=dashed]
    step_build_manifest -> done

    subgraph cluster_legend {
        label="Key\n\"What the shapes mean\""
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_bash [label="Automated Step", shape=box, fillcolor="#bbdefb"]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_cond [label="Decision Point", shape=diamond, fillcolor="#fff9c4"]
        leg_start [label="Start / Done", shape=oval, fillcolor="#e0e0e0"]
        leg_bash -> leg_agent -> leg_cond -> leg_start [style=invis]
    }
}