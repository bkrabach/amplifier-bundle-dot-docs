// This recipe turns raw investigation diagrams into polished, readable charts — then checks their quality before finishing.
digraph dotfiles_synthesis {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Diagram Polishing Pipeline\nTurns raw investigation notes into clean, readable diagrams"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="748e278448920dd4891f27850f5a2b29245d8424163f9f3ec34b914d09084107"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done!", shape=oval, fillcolor="#e0e0e0"]

    step_inventory_dots [label="Scan for Diagrams\n\"What did the investigation produce?\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="set -euo pipefail INV='{{investigation_dir}}'  echo '=== INVESTIGATION DIRECTORY STRUCTURE ===' find"]
    step_prepare_output [label="Set Up Workspace\n\"Make room for results\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="set -euo pipefail mkdir -p '{{output_dir}}' mkdir -p '{{output_dir}}/.discovery' echo 'Output direct"]
    step_synthesize [label="Build the Diagrams\n\"Combine findings into pictures\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="dot-graph:dot-author"]
    step_quality_review [label="Check Quality\n\"Are the diagrams clear & correct?\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="dot-graph:diagram-reviewer"]
    cond_step_fix_if_failed [label="Quality check\nfailed?", shape=diamond, fillcolor="#fff9c4"]
    step_fix_if_failed [label="Fix the Issues\n\"Address reviewer feedback\"", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="dot-graph:dot-author"]
    step_validate_output [label="Final Validation\n\"Confirm everything is ready\"", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="set -euo pipefail python3 - <<'PYEOF' import sys from pathlib import Path  # Add tools directory to "]

    start -> step_inventory_dots
    step_inventory_dots -> step_prepare_output
    step_prepare_output -> step_synthesize
    step_synthesize -> step_quality_review
    step_quality_review -> cond_step_fix_if_failed
    cond_step_fix_if_failed -> step_fix_if_failed [label="review_verdict == FAIL"]
    step_quality_review -> step_validate_output
    cond_step_fix_if_failed -> step_validate_output [label="skip", style=dashed]
    step_validate_output -> done

    subgraph cluster_legend {
        label="Guide\n\"What the shapes mean\""
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_bash [label="Script Step", shape=box, fillcolor="#bbdefb"]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_cond [label="Condition", shape=diamond, fillcolor="#fff9c4"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_bash -> leg_agent -> leg_cond -> leg_start [style=invis]
    }
}