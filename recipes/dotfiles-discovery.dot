// This recipe scans all the repos in your dotfiles profile, figures out what changed, and rebuilds their documentation graphs.
digraph dotfiles_discovery {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Dotfiles Discovery\nScans your repos, figures out what changed, and builds fresh documentation"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="7741445b835a28f4d95ee8cc4b39314c1cd7125bddf81c2da356ebb1c463edef"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done!", shape=oval, fillcolor="#e0e0e0"]

    subgraph cluster_setup {
        label="Getting Ready\n\"What repos do we have?\""
        style="filled,rounded"
        fillcolor="#f9f9f9"
        color="#999999"

        step_read_profile [label="Read Your\nRepo List", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json import ast import sys from pathlib import Path  try:     import yaml ex"]
        step_determine_tiers [label="Decide What\nEach Repo Needs", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json import ast import sys from pathlib import Path  sys.path.insert(0, str("]
        step_display_plan [label="Show the\nGame Plan", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json  import ast TIER_LABELS = {     -1: 'SKIP (not found)',      0: 'SKIP ("]

        start -> step_read_profile
        step_read_profile -> step_determine_tiers
        step_determine_tiers -> step_display_plan
    }

    gate_investigation [label="Human\nApproves?\n\"Look good?\"", shape=diamond, fillcolor="#ffe0b2", tooltip="## Discovery Plan — Ready for Synthesis  The following tier plan was computed from your profile and "]
    step_display_plan -> gate_investigation
    subgraph cluster_investigation {
        label="Deep Dive\n\"What's inside each repo?\""
        style="filled,rounded"
        fillcolor="#f9f9f9"
        color="#999999"

        step_process_repos [label="Prepare\nEach Repo\n(for each)", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json  import ast entry = ast.literal_eval('''{{repo_entry}}''') repo  = entr"]
        step_filter_tiers [label="Sort Repos by\nWork Needed", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json, ast  tier_plan = ast.literal_eval('''{{tier_plan}}''')  prescan_repos "]
        step_prescan_repos [label="Quick Scan\nEach Repo\n(for each)", shape=box, fillcolor="#e0e0e0", style="filled,rounded,dashed", tooltip="prescan-repos"]
        step_investigate_repos [label="Investigate\nEach Repo\n(for each)", shape=box, fillcolor="#e0e0e0", style="filled,rounded,dashed", tooltip="investigate-repos"]

        gate_investigation -> step_process_repos
        step_process_repos -> step_filter_tiers
        step_filter_tiers -> step_prescan_repos
        step_prescan_repos -> step_investigate_repos
    }

    subgraph cluster_synthesis {
        label="Wrap-Up\n\"Build the docs and tidy up\""
        style="filled,rounded"
        fillcolor="#f9f9f9"
        color="#999999"

        step_run_synthesis [label="Build the\nDocumentation\n(for each)", shape=box, fillcolor="#e0e0e0", style="filled,rounded,dashed", tooltip="run-synthesis"]
        step_check_content_hash [label="Anything\nActually Change?", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json import ast import sys from pathlib import Path  # Add tools directory t"]
        step_tier3_analysis [label="AI Quality\nCheck\n(for each)", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="dot-graph:dot-author"]
        step_write_metadata [label="Save a Record\nof This Run", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json import ast import sys from datetime import datetime, timezone from path"]
        step_final_summary [label="Show the\nFinal Report", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json  import ast dotfiles_root = '{{dotfiles_root}}' metadata_raw = '{{metad"]
        step_reconcile_stale_repos [label="Clean Up\nOld Repos", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import sys from pathlib import Path  sys.path.insert(0, '/home/bkrabach/dev/dot-doc"]

        step_investigate_repos -> step_run_synthesis
        step_run_synthesis -> step_check_content_hash
        step_check_content_hash -> step_tier3_analysis
        step_tier3_analysis -> step_write_metadata
        step_write_metadata -> step_final_summary
        step_final_summary -> step_reconcile_stale_repos
    }

    step_reconcile_stale_repos -> done

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_bash [label="Script Step", shape=box, fillcolor="#bbdefb"]
        leg_agent [label="AI Agent Step", shape=box, fillcolor="#c8e6c9"]
        leg_sub [label="Sub-Recipe Call", shape=box, fillcolor="#e0e0e0", style="filled,rounded,dashed"]
        leg_gate [label="Approval Gate", shape=diamond, fillcolor="#ffe0b2"]
        leg_start [label="Start / End", shape=oval, fillcolor="#e0e0e0"]
        leg_bash -> leg_agent -> leg_sub -> leg_gate -> leg_start [style=invis]
    }
}